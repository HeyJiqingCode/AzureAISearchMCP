# Azure AI Search endpoint (required)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net

# Azure AI Search query key (read-only access)
AZURE_SEARCH_QUERY_KEY=your-query-key

# Azure AI Search admin key (required for agentic_retrieval tool)
# Provides create/update privileges—treat as sensitive
AZURE_SEARCH_ADMIN_KEY=your-admin-key

# Optional: standard search client-side timeout in seconds (default 30)
# AZURE_SEARCH_TIMEOUT=30

# Optional: agentic_retrieval client-side safety timeout in seconds (default 90)
# This is separate from the per-request max_runtime_seconds tool argument.
# AZURE_SEARCH_AGENTIC_TIMEOUT=90
# AZURE_SEARCH_AGENTIC_TIMEOUT_BUFFER=30
